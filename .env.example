# Blog content: omit or leave unset to use dummy posts. Set to "true" to fetch from Sanity.
# NEXT_PUBLIC_USE_SANITY=true

# Sanity (for blog content)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-26
SANITY_API_WRITE_TOKEN=your-sanity-write-token

# Contact form (Resend)
RESEND_API_KEY=re_your_resend_api_key
CONTACT_FORM_RECIPIENT=your-email@example.com
# RESEND_FROM_EMAIL=Reflections Contact <onboarding@resend.dev>
